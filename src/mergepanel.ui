      <item><widget class="QLabel" name="volumeLabel">
       <property name="text"><string>100%</string></property>
       <property name="minimumWidth"><number>40</number></property>
       <property name="alignment"><set>Qt::AlignRight|Qt::AlignVCenter</set></property>
      </widget></item>
