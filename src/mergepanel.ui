     <item><widget class="QPushButton" name="removeFileBtn">
      <property name="text"><string>移除选中</string></property>
     </widget></item>
     <item><widget class="QPushButton" name="clearBtn">
      <property name="text"><string>清空</string></property>
     </widget></item>
    </layout>
   </item>

   <!-- 音量组（预留，当前版本隐藏） -->
   <item>
    <widget class="QGroupBox" name="volumeGroup">
     <property name="title"><string>选中文件音量</string></property>
     <property name="visible"><bool>false</bool></property>
     <layout class="QHBoxLayout" name="volumeLayout">
      <property name="margin"><number>4</number></property>
      <item><widget class="QSlider" name="volumeSlider">
       <property name="minimum"><number>0</number></property>
       <property name="maximum"><number>200</number></property>
       <property name="value"><number>100</number></property>
       <property name="orientation"><enum>Qt::Horizontal</enum></property>
