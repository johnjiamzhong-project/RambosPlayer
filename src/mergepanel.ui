     <item><widget class="QPushButton" name="browseBtn">
      <property name="text"><string>浏览</string></property>
      <property name="maximumWidth"><number>50</number></property>
     </widget></item>
    </layout>
   </item>

   <!-- 开始 / 取消 -->
   <item>
    <layout class="QHBoxLayout" name="actionRow">
     <item><widget class="QPushButton" name="startBtn">
      <property name="text"><string>开始合并</string></property>
