{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake --build build --config Debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$msCompile",
            "windows": {
                "command": "cmake --build build --config Debug",
                "problemMatcher": "$msCompile"
            },
            "linux": {
                "command": "cmake --build build-arm64",
                "problemMatcher": "$gcc"
            }
        }
    ]
}
